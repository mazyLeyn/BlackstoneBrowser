<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="Görünüm">
        <ListPreference
            app:defaultValue="dark"
            app:entries="@array/theme_entries"
            app:entryValues="@array/theme_values"
            app:key="theme"
            app:title="Tema" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Arama">
        <ListPreference
            app:defaultValue="google"
            app:entries="@array/search_engine_entries"
            app:entryValues="@array/search_engine_values"
            app:key="search_engine"
            app:title="Varsayılan Arama Motoru" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Gelişmiş">
        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:key="javascript_enabled"
            app:title="JavaScript" />
        <SwitchPreferenceCompat
            app:defaultValue="false"
            app:key="desktop_mode"
            app:title="Masaüstü Modu" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Veri Temizleme">
        <Preference
            app:key="clear_cookies"
            app:title="Çerezleri Temizle" />
        <Preference
            app:key="clear_cache"
            app:title="Önbelleği Temizle" />
        <Preference
            app:key="clear_history"
            app:title="Geçmişi Temizle" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Hakkında">
        <Preference
            app:key="version"
            app:title="Uygulama Sürümü"
            app:summary="v1.3.6" />
        <Preference
            app:key="licenses"
            app:title="Lisans Bilgisi" />
        <Preference
            app:key="github"
            app:title="GitHub Bağlantısı" />
    </PreferenceCategory>

</PreferenceScreen>